# Copy this file to server/.env and fill in real values before starting the server.

PORT=5000
NODE_ENV=development

# MongoDB connection string (use MongoDB Atlas in production)
MONGODB_URI=mongodb://127.0.0.1:27017/journal-management-system

# Required — generate a long random string for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

JWT_EXPIRES_IN=7d

# Comma-separated list of frontend origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cloudinary (paper file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (email notifications) — optional, mailer no-ops if unset
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
