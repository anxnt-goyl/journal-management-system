# Copy this file to client/.env.production (or .env) before deploying.
#
# Leave unset for local development — Vite's dev server proxies /api to
# http://localhost:5000 automatically (see vite.config.ts).
#
# In production, set this to your deployed API's full URL, e.g.:
#   VITE_API_BASE_URL=https://api.your-journal.com/api
VITE_API_BASE_URL=
